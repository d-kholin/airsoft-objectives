[Unit]
Description=Raspi-Box Airsoft Objective
After=graphical.target

[Service]
Type=simple
User=michael
Environment=SDL_VIDEODRIVER=wayland
Environment=WAYLAND_DISPLAY=wayland-0
Environment=XDG_RUNTIME_DIR=/run/user/1000
WorkingDirectory=/home/michael/airsoft
ExecStart=/usr/bin/python3 /home/michael/airsoft/main.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
